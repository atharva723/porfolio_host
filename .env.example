# Copy this file to ".env" for local development and fill in your key.
# On Vercel, set these in: Project -> Settings -> Environment Variables.

# Which provider to use: groq | mistral | gemini
LLM_PROVIDER=groq

# Your API key for the chosen provider.
#   Groq (recommended, generous free tier, no card): https://console.groq.com/keys
#   Mistral:                                          https://console.mistral.ai/
#   Gemini:                                           https://aistudio.google.com/apikey
LLM_API_KEY=your_api_key_here

# Optional: override the default model.
#   groq    -> llama-3.1-8b-instant (default) or llama-3.3-70b-versatile
#   mistral -> mistral-small-latest
#   gemini  -> gemini-1.5-flash
# LLM_MODEL=
